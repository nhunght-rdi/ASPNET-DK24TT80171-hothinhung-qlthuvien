@model ThuVienSo.Data.User
@{ ViewData["Title"] = "Đăng Ký"; }

<div class="auth-wrap">
  <div class="auth-card" style="max-width:520px;">
    <div class="auth-logo"><i class="fas fa-user-plus"></i></div>
    <h2 class="auth-title mb-1">Tạo Tài Khoản</h2>
    <p class="text-center text-muted small mb-4">Đăng ký để mượn sách tại Thư Viện Số TVU</p>

    @if (ViewBag.Error != null)
    {
      <div class="alert alert-danger py-2 small"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</div>
    }

    <form method="post" asp-action="DangKy">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label">Họ và Tên <span class="text-danger">*</span></label>
          <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" required />
        </div>
        <div class="col-12">
          <label class="form-label">Email <span class="text-danger">*</span></label>
          <input asp-for="Email" type="email" class="form-control" placeholder="email@tvu.edu.vn" required />
        </div>
        <div class="col-md-6">
          <label class="form-label">Số Điện Thoại</label>
          <input asp-for="PhoneNumber" class="form-control" placeholder="0912345678" />
        </div>
        <div class="col-md-6">
          <label class="form-label">Địa Chỉ</label>
          <input asp-for="Address" class="form-control" placeholder="Trà Vinh" />
        </div>
        <div class="col-12">
          <label class="form-label">Mật Khẩu <span class="text-danger">*</span></label>
          <input asp-for="Password" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" required />
        </div>
        <div class="col-12">
          <label class="form-label">Xác Nhận Mật Khẩu <span class="text-danger">*</span></label>
          <input name="confirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" required />
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary w-100 py-2">
            <i class="fas fa-user-plus me-2"></i>Đăng Ký
          </button>
        </div>
      </div>
    </form>

    <hr class="my-3">
    <p class="text-center small mb-0">
      Đã có tài khoản? <a asp-action="DangNhap" style="color:var(--navy);font-weight:600;">Đăng nhập</a>
    </p>
  </div>
</div>
