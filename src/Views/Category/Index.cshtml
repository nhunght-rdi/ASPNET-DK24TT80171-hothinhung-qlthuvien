@model IEnumerable<ThuVienSo.Data.Category>
@{ ViewData["Title"] = "Quản Lý Thể Loại"; }

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-tags me-2" style="color:var(--gold-light)"></i>Quản Lý Thể Loại</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <p class="text-muted small mb-0">Tổng cộng <strong>@Model.Count()</strong> thể loại</p>
        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="fas fa-plus me-1"></i>Thêm thể loại
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 card">
            <div class="card-body">
                <i class="fas fa-tags fa-3x text-muted mb-3"></i>
                <p class="text-muted">Chưa có thể loại nào. Hãy thêm thể loại đầu tiên.</p>
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Thêm thể loại
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Tên Thể Loại</th>
                            <th class="text-center">Số Sách</th>
                            <th class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int stt = 1; }
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="text-muted">@(stt++)</td>
                                <td>
                                    <i class="fas fa-tag me-2 text-primary"></i>
                                    <strong>@c.CategoryName</strong>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(c.Books.Any() ? "bg-primary" : "bg-secondary")">
                                        @c.Books.Count sách
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@c.CategoryId" class="btn btn-sm btn-warning me-1">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" asp-action="Delete" asp-route-id="@c.CategoryId" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Xóa thể loại \'@c.CategoryName\'?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
