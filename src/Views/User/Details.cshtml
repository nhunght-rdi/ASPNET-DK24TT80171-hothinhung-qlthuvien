@model ThuVienSo.Data.User
@{ ViewData["Title"] = "Chi Tiết Độc Giả"; }
<div class="page-header"><div class="container"><h1>@Model.FullName</h1></div></div>
<div class="container py-4"><div class="row g-4">
  <div class="col-md-4"><div class="card text-center"><div class="card-body py-4">
    <div style="width:80px;height:80px;background:var(--navy);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:2rem;color:white;"><i class="fas fa-user"></i></div>
    <h5>@Model.FullName</h5>
    <p class="text-muted small mb-2">@Model.Email</p>
    <span class="badge-status @(Model.Status=="Active"?"status-hoatdong":"status-bikhoa")">@(Model.Status=="Active"?"Hoạt động":"Bị khóa")</span>
    <div class="mt-3 text-muted small">
      <div><i class="fas fa-id-card me-1"></i>@Model.UserId</div>
      <div><i class="fas fa-calendar me-1"></i>@Model.RegisterDate.ToString("dd/MM/yyyy")</div>
      @if (!string.IsNullOrEmpty(Model.PhoneNumber)) { <div><i class="fas fa-phone me-1"></i>@Model.PhoneNumber</div> }
    </div>
    @if (Model.ViolationCount > 0) { <div class="mt-2"><span class="badge bg-danger">Vi phạm: @Model.ViolationCount lần</span></div> }
  </div></div></div>
  <div class="col-md-8"><div class="card mb-3">
    <div class="card-header"><h5><i class="fas fa-history me-2"></i>Lịch Sử Mượn</h5></div>
    <div class="card-body p-0"><div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead><tr><th>Sách</th><th>Ngày Mượn</th><th>Hạn Trả</th><th>Trạng Thái</th></tr></thead>
        <tbody>
          @foreach (var br in Model.BorrowRecords ?? Enumerable.Empty<BorrowRecord>())
          {
            <tr><td style="font-size:.85rem;">@br.Book?.BookTitle</td><td style="font-size:.82rem;">@br.BorrowDate.ToString("dd/MM/yyyy")</td><td style="font-size:.82rem;">@br.DueDate.ToString("dd/MM/yyyy")</td>
            <td><span class="badge-status" style="font-size:.72rem;">@br.Status</span></td></tr>
          }
          @if (!(Model.BorrowRecords?.Any() ?? false)) { <tr><td colspan="4" class="text-center text-muted py-3">Chưa có lịch sử mượn</td></tr> }
        </tbody>
      </table>
    </div></div>
  </div>
  <div class="d-flex gap-2"><a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Quay lại</a><a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-warning"><i class="fas fa-edit me-1"></i>Chỉnh Sửa</a></div>
  </div>
</div></div>